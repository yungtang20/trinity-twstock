  "data_rules": [
    "所有 API 回傳必須包含 success 欄位（boolean）",
    "失敗時必須有 error 欄位（string）",
    "列表資料放在 data 陣列中",
    "date 格式為 YYYY-MM-DD",
    "數值為 number，不要字串",
    "stock_id 為字串（如 '2330'）",
    "漲跌幅 changePercent 為百分比數值（如 1.52 代表 1.52%）",
    "不要使用陣列索引作為 keys（如 data[0]），使用物件欄位名稱"
  ]
}
