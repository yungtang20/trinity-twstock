# -*- coding: utf-8 -*-
"""
test_deprecated_modules.py — 已淘汰模組驗證

確認不再使用的模組已被移除或標記為 deprecated。
"""
from __future__ import annotations

from pathlib import Path


# 已淘汰的模組（不應存在於 repo 中）
DEPRECATED_MODULES = [
    "twstock/strategy/kronos_engine.py",
    "twstock/strategy/vision_engine.py",
    "twstock/official/suspended.py",
    "twstock/official/utils.py",
    "twstock/polars_compat.py",
]


def test_strategy_runner_does_not_import_deprecated():
    """strategy_runner.py 不應 import 已淘汰模組。"""
    src = Path("twstock/strategy_runner.py").read_text(encoding="utf-8")

    assert "kronos_engine" not in src, "strategy_runner 不應引用 kronos_engine"
    assert "vision_engine" not in src, "strategy_runner 不應引用 vision_engine"
    assert "polars_compat" not in src, "strategy_runner 不應引用 polars_compat"
    assert "prediction_strategy" not in src, "strategy_runner 不應引用 prediction_strategy"


def test_main_does_not_import_deprecated():
    """main.py 不應直接 import 已淘汰模組。"""
    src = Path("twstock/main.py").read_text(encoding="utf-8")

    assert "kronos_engine" not in src, "main 不應引用 kronos_engine"
    assert "vision_engine" not in src, "main 不應引用 vision_engine"
    assert "polars_compat" not in src, "main 不應引用 polars_compat"
